{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AdSettings": {
    "ForestRootDomain": "lab.local",
    "Domains": [ "lab.local", "new.lab.local", "second.lab.local" ],
    "DefaultUserOuFormat": "OU=Users,OU=_Managed,DC={0},DC={1}",
    "AdminUserOuFormat": "OU=_AdminAccounts,DC={0},DC={1}",
    "AccessControl": {
      "GeneralAccessGroups": [ "L2", "L3", "Domain Admins", "Enterprise Admins" ],
      "HighPrivilegeGroups": [ "L3", "Domain Admins", "Enterprise Admins" ]
    },
    "Provisioning": {
      "DefaultUserGroups": [ "Domain Users" ],
      "OptionalUserGroups": [ "Group1", "Group2", "Group3" ],
      "DefaultAdminGroups": [ "Domain Admins" ]
    }
  }
}
