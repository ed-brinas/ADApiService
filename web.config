<configuration>
  <system.webServer>
    <handlers>
      <remove name="WebDAVModule" />
    </handlers>
    
    <rewrite>
      <rules>
        <rule name="Handle Preflight" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_METHOD}" pattern="^OPTIONS$" />
          </conditions>
          <action type="CustomResponse" statusCode="204" statusReason="No Content" statusDescription="No Content" />
        </rule>
      </rules>
    </rewrite>

    <cors enabled="true" failUnlistedOrigins="true">
        <add origin="http://">
            <allowMethods>
                <add method="GET" />
                <add method="POST" />
                <add method="PUT" />
                <add method="DELETE" />
                <add method="OPTIONS" />
            </allowMethods>
            <allowHeaders allowAllRequestedHeaders="true" />
            <allowCredentials enabled="true" />
        </add>
    </cors>
    <httpProtocol>
      <customHeaders>
        <add name="Access-Control-Allow-Origin" value="http://" />
        <add name="Access-Control-Allow-Methods" value="GET, POST, PUT, DELETE, OPTIONS" />
        <add name="Access-Control-Allow-Headers" value="Content-Type, Authorization" />
        <add name="Access-Control-Allow-Credentials" value="true" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
