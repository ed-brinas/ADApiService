<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Remove modules that can hijack OPTIONS -->
    <modules>
      <remove name="WebDAVModule" />
    </modules>
    <handlers>
      <remove name="WebDAV" />
    </handlers>

    <!-- Allow ONLY OPTIONS anonymously; everything else follows normal auth -->
    <security>
      <authorization>
        <add accessType="Allow" users="?" verbs="OPTIONS" />
        <!-- Your existing rules (if any) can remain -->
      </authorization>
    </security>

    <!-- If you previously added CORS headers here, you can keep them,
         but they don't fix a 401; the app must handle OPTIONS. -->
    <!--
    <httpProtocol>
      <customHeaders>
        <add name="Access-Control-Allow-Origin" value="http://adadmin.ncc.local" />
        <add name="Access-Control-Allow-Methods" value="GET, POST, PUT, DELETE, OPTIONS" />
        <add name="Access-Control-Allow-Headers" value="Content-Type, Authorization" />
        <add name="Access-Control-Allow-Credentials" value="true" />
      </customHeaders>
    </httpProtocol>
    -->

  </system.webServer>
</configuration>
